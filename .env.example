# .env.example — コピーして .env を作成し、強力な値に変更してください。
# .env は絶対にコミットしないこと（.gitignore 済み想定）。
#
# 生成例: openssl rand -base64 24

# --- PostgreSQL 管理ユーザー (スーパーユーザー / マイグレーション用) ---
POSTGRES_USER=postgres
# 強力なランダム値に変更
POSTGRES_PASSWORD=change_me_admin_strong_secret
POSTGRES_DB=hr_saas

# --- HR アプリ用 DB ロール (hr_app — NOBYPASSRLS) ---
# アプリサーバーが常時使用するロール。マイグレーション後に GRANT される。
# パスワードは POSTGRES_PASSWORD と異なる値を使用してください。
HR_APP_DB_PASSWORD=change_me_app_strong_secret

# --- 管理 DSN (サーバ起動マイグレーション / cmd/migrate 用) ---
# 未設定の場合は POSTGRES_USER / POSTGRES_PASSWORD にフォールバック。
# DB_ADMIN_USER=postgres
# DB_ADMIN_PASSWORD=change_me_admin_strong_secret

# --- アプリ設定 ---
APP_ENV=development
HTTP_PORT=8080
MIGRATE_ON_STARTUP=true

# --- CORS ---
# 開発時はデフォルト(localhost:3000)で動作。本番は必ず明示設定。
# CORS_ALLOW_ORIGINS=https://your-domain.example.com
