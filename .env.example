# .env.example — コピーして .env を作成し、強力な値に変更してください。
# .env は絶対にコミットしないこと（.gitignore 済み想定）。
#
# 生成例: openssl rand -base64 32

# ---------------------------------------------------------------------------
# PostgreSQL 管理ユーザー (スーパーユーザー / マイグレーション用)
# ---------------------------------------------------------------------------
POSTGRES_USER=postgres
# 強力なランダム値に変更
POSTGRES_PASSWORD=change_me_admin_strong_secret
POSTGRES_DB=hr_saas

# ---------------------------------------------------------------------------
# HR アプリ用 DB ロール (hr_app — NOBYPASSRLS)
# ---------------------------------------------------------------------------
# アプリサーバーが常時使用するロール。マイグレーション後に GRANT される。
# パスワードは POSTGRES_PASSWORD と異なる値を使用してください。
HR_APP_DB_PASSWORD=change_me_app_strong_secret

# ---------------------------------------------------------------------------
# アプリ DB 接続 (hr_app ロール)
# ---------------------------------------------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_USER=hr_app
DB_PASSWORD=change_me_app_strong_secret
DB_NAME=hr_saas
# 本番では require / verify-ca / verify-full に変更すること。
DB_SSLMODE=disable

# URL 形式で指定する場合 (DB_* より優先)。実値は書かないこと。
# DATABASE_URL=postgres://hr_app:change_me_app_strong_secret@localhost:5432/hr_saas?sslmode=disable

# ---------------------------------------------------------------------------
# Docker Compose: PostgreSQL ホスト公開ポート
# ---------------------------------------------------------------------------
# docker-compose の db サービスがホストへ公開する PostgreSQL ポート。
# 他のローカル PostgreSQL(別プロジェクト等)との競合回避のため、既定を 5432 からずらしている。
# - コンテナ内ポートは 5432 固定。compose 内の api はコンテナ間通信(DB_HOST=db/DB_PORT=5432)のため本値の影響を受けない。
# - ホスト(psql / GUI / ホスト実行のアプリ・cmd/migrate)から接続する場合は localhost:${DB_HOST_PORT} を使う。
#   その際は上の DB_PORT / DATABASE_URL のポートも DB_HOST_PORT と一致させること。
DB_HOST_PORT=15432

# ---------------------------------------------------------------------------
# 管理 DSN (サーバ起動マイグレーション / cmd/migrate 用)
# ---------------------------------------------------------------------------
# 未設定の場合は POSTGRES_USER / POSTGRES_PASSWORD にフォールバック。
# 本番では必ず専用管理ユーザーを設定すること。
# DB_ADMIN_USER=postgres
# DB_ADMIN_PASSWORD=change_me_admin_strong_secret
# ADMIN_DATABASE_URL=postgres://postgres:change_me_admin_strong_secret@localhost:5432/hr_saas?sslmode=disable

# ---------------------------------------------------------------------------
# アプリ設定
# ---------------------------------------------------------------------------
APP_ENV=development
HTTP_PORT=8080
# 開発環境では true、本番では false にして別途 pre-deploy ステップで実行すること。
MIGRATE_ON_STARTUP=true

# ---------------------------------------------------------------------------
# CORS
# ---------------------------------------------------------------------------
# 開発時はデフォルト(localhost:3000)で動作。本番は必ず明示設定。
CORS_ALLOW_ORIGINS=http://localhost:3000
# 本番例: CORS_ALLOW_ORIGINS=https://your-domain.example.com

# ---------------------------------------------------------------------------
# セッション Cookie 設定 (P1.3a 認証インフラ)
# ---------------------------------------------------------------------------
# HTTP-only セッション Cookie の名前。
SESSION_COOKIE_NAME=hr_session

# セッショントークンの有効期間。Go の duration 文字列 (例: 24h, 8h, 168h)。
SESSION_TTL=24h

# 本番では必ず true に設定すること (HTTPS 専用)。
# 開発環境では false のまま使用可。
# 注意: APP_ENV が development 以外のとき false のまま起動するとサーバーが拒否します。
SESSION_COOKIE_SECURE=false

# SameSite 属性: lax (デフォルト), strict, none。
# none を使う場合は SESSION_COOKIE_SECURE=true が必須 (モダンブラウザ要件)。
SESSION_COOKIE_SAMESITE=lax

# ---------------------------------------------------------------------------
# セッション署名/暗号化キー (gorilla/securecookie 方式; P1.3b で有効化)
# ---------------------------------------------------------------------------
# SESSION_HASH_KEY: HMAC 署名用。32 バイト以上のランダム値 (hex)。
# SESSION_BLOCK_KEY: AES 暗号化用。16/24/32 バイトのランダム値 (hex)。
# 生成例: openssl rand -hex 32
SESSION_HASH_KEY=change_me_session_hash_key_32_or_more_hex_bytes
SESSION_BLOCK_KEY=change_me_session_block_key_16_24_or_32_hex_bytes

# ---------------------------------------------------------------------------
# フィールドレベル暗号化鍵 (口座番号/マイナンバー等の機微PII列暗号化 ST-LM-07)
# ---------------------------------------------------------------------------
# AES-256-GCM 用の32バイトキーを base64 標準エンコードした値。
# 生成例: openssl rand -base64 32
#
# 本番環境では AWS Secrets Manager / GCP Secret Manager / Vault 等から
# 実行時にインジェクトすること。実際の鍵値を絶対にリポジトリにコミットしないこと。
#
# 未設定時は開発環境では起動時に一時キーが生成されます（警告あり）。
# 一時キーで暗号化したデータは再起動後に復号できないため、
# 永続データを扱う環境では必ず設定してください。
FIELD_ENCRYPTION_KEY=change_me_base64_encoded_32_byte_aes256_key_placeholder
